# scripts/.env.example
# Copy to scripts/.env and fill in real values. `.env` is gitignored.
#
# These keys are used by:
#   - scripts/seed_supabase.js  (Node, idempotent demo seed)
#   - scripts/seed_demo.sh      (thin shell wrapper)
#
# How to get them
#   * SUPABASE_URL: your self-hosted Supabase URL (currently https://supabase.0for0.com).
#   * SUPABASE_SERVICE_ROLE: Studio → Settings → API → "service_role" key.
#     DANGER: this key bypasses RLS. Never embed it in the Flutter apps, never
#     commit it. Only used in scripts/ from a trusted developer machine.
#   * SUPABASE_ANON_KEY: optional — only needed for the cURL verification snippet
#     in SETUP_SUPABASE.md; the anon key is already hardcoded in
#     win_time_*_mobilapp/lib/core/config/wintime_supabase_config.dart since RLS
#     protects it.

SUPABASE_URL=https://supabase.0for0.com
SUPABASE_SERVICE_ROLE=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_ME
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_ME
