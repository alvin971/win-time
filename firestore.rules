rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function isRestaurantOwner(uid) {
      return isSignedIn() && userRole(uid) == 'restaurantOwner';
    }

    function ownsRestaurant(rid) {
      return isSignedIn()
        && get(/databases/$(database)/documents/restaurants/$(rid)).data.ownerId == request.auth.uid;
    }

    // ─── Users ────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && request.resource.data.role in ['client', 'restaurantOwner', 'restaurantManager', 'restaurantStaff', 'admin'];
      allow update: if isOwner(uid)
        && request.resource.data.role == resource.data.role; // role immuable côté client
      allow delete: if false; // jamais
    }

    // ─── Restaurants ──────────────────────────────────────────────────────
    match /restaurants/{rid} {
      allow read: if isSignedIn()
        && resource.data.isActive == true
        && resource.data.isApproved == true;

      // Le owner peut toujours lire son propre resto même non-approuvé
      allow read: if ownsRestaurant(rid);

      allow create: if isRestaurantOwner(request.auth.uid)
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.geohash is string
        && request.resource.data.geohash.size() >= 4;

      allow update: if ownsRestaurant(rid)
        && request.resource.data.ownerId == resource.data.ownerId; // ownerId immuable

      allow delete: if ownsRestaurant(rid);

      // Sub-collections (categories, products) — owner uniquement en write,
      // tout signed-in user en read.
      match /categories/{cid} {
        allow read: if isSignedIn();
        allow write: if ownsRestaurant(rid);
      }

      match /products/{pid} {
        allow read: if isSignedIn();
        allow write: if ownsRestaurant(rid);
      }
    }

    // ─── Orders ───────────────────────────────────────────────────────────
    match /orders/{oid} {
      allow read: if isSignedIn() && (
        resource.data.customerId == request.auth.uid ||
        ownsRestaurant(resource.data.restaurantId)
      );

      allow create: if isSignedIn()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.restaurantId is string;

      // Customer peut annuler tant que pending. Owner peut update statut.
      allow update: if isSignedIn() && (
        (resource.data.customerId == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.status == 'cancelled')
        ||
        ownsRestaurant(resource.data.restaurantId)
      );

      allow delete: if false;
    }

    // ─── Default deny ─────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
